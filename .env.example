# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
BETTER_AUTH_SECRET="generate-a-long-random-secret"
BETTER_AUTH_URL="http://localhost:3000"

# Database (Railway Postgres or local Docker)
# Local: postgresql://influence:influence@localhost:5432/influence?schema=public
# Railway: use the DATABASE_URL from your Postgres service (public URL for local, internal for Railway app)
DATABASE_URL="postgresql://influence:influence@localhost:5432/influence?schema=public"

# Instagram / Meta
META_APP_ID=""
META_APP_SECRET=""
META_REDIRECT_URI="http://localhost:3000/api/instagram/callback"
INSTAGRAM_GRAPH_API_VERSION="v21.0"

# Encrypt OAuth tokens at rest
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=""
